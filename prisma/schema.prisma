// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/prisma"
}

datasource db {
  provider = "sqlite"
}

model preorder {
  id              String         @id @default(uuid())
  name            String
  productsCovered Int
  preorderCase    PreorderCase
  startDate       DateTime
  endDate         DateTime?
  status          PreorderStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PreorderCase {
  REGARDLESS_OF_STOCK
  OUT_OF_STOCK
}

enum PreorderStatus {
  ACTIVE
  INACTIVE
}
